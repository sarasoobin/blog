{
  "permissions": {
    "allow": [
      "Bash(head:*)",
      "Bash(bundle exec:*)",
      "Bash(claude plugins:*)",
      "Bash(bundle info:*)",
      "Bash(git add:*)",
      "Bash(git tag:*)",
      "Bash(git push:*)",
      "Bash(gh run:*)",
      "Bash(git commit:*)",
      "PowerShell(gh run *)",
      "WebFetch(domain:sarasoobin.github.io)",
      "PowerShell(Get-Date *)",
      "Bash(git mv *)",
      "Bash(git check-ignore *)",
      "Bash(echo \"exit=$?\")",
      "Bash(git rm *)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:4000/blog/)",
      "Bash(curl -s \"https://sarasoobin.github.io/blog/assets/style.css?$\\(date +%s\\)\")",
      "Bash(curl -s \"https://sarasoobin.github.io/blog/?$\\(date +%s\\)\")",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" \"https://sarasoobin.github.io/blog/posts/\")",
      "Bash(curl -s https://sarasoobin.github.io/blog/posts/?__CMDSUB_OUTPUT__)",
      "Read(//tmp/**)",
      "Bash(curl -s \"https://sarasoobin.github.io/blog/feed.xml\")",
      "PowerShell(\\(Invoke-RestMethod \"https://api.github.com/repos/sarasoobin/blog/actions/runs?per_page=3\"\\).workflow_runs | Select-Object display_title,status,conclusion,created_at | Format-List)",
      "PowerShell($r = Invoke-WebRequest \"https://sarasoobin.github.io/blog/\" -UseBasicParsing; $r.Content -split \"`n\" | Select-String -Pattern \"card-title|featured-title|umc\" | Select-Object -First 20)"
    ]
  }
}
